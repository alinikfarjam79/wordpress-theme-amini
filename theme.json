{
  "version": 1,
  "settings": {
    "layout": {
      "contentSize": "1440px",
      "wideSize": "1600px"
    },

    "color": {
      "defaultPalette": false,
      "palette": [
        { "name": "Primary", "slug": "primary", "color": "#009E00" },
        { "name": "Primary Dark", "slug": "primary-dark", "color": "#008A00" },

        { "name": "TopBar", "slug": "topbar", "color": "#CC9900" },
        { "name": "Secondary", "slug": "secondary", "color": "#F7F4EE" },

        { "name": "Background", "slug": "background", "color": "#FFFFFF" },
        { "name": "Surface", "slug": "surface", "color": "#F9FAFB" },

        { "name": "Text", "slug": "text", "color": "#111827" },
        { "name": "Text Muted", "slug": "text-muted", "color": "#6B7280" },

        { "name": "Border", "slug": "border", "color": "#E5E7EB" },

        { "name": "Orange", "slug": "orange", "color": "#E35D30" },

        { "name": "Success", "slug": "success", "color": "#16A34A" },
        { "name": "Warning", "slug": "warning", "color": "#F59E0B" },
        { "name": "Error", "slug": "error", "color": "#EF4444" }
      ]
    },

    "typography": {
      "fontFamilies": [
        {
          "name": "IRANSans",
          "slug": "iransans",
          "fontFamily": "IRANSans, sans-serif"
        }
      ],

      "fontSizes": [
        { "name": "XS", "slug": "xs", "size": "12px" },
        { "name": "Small", "slug": "sm", "size": "14px" },
        { "name": "Base", "slug": "base", "size": "16px" },
        { "name": "Medium", "slug": "md", "size": "18px" },
        { "name": "Large", "slug": "lg", "size": "24px" },
        { "name": "XL", "slug": "xl", "size": "32px" },
        { "name": "2XL", "slug": "2xl", "size": "40px" },
        { "name": "3XL", "slug": "3xl", "size": "56px" }
      ],

      "fontWeight": true,
      "lineHeight": true
    },

    "spacing": {
      "units": ["px", "rem"],
      "spacingSizes": [
        { "name": "XS", "slug": "xs", "size": "8px" },
        { "name": "SM", "slug": "sm", "size": "12px" },
        { "name": "MD", "slug": "md", "size": "20px" },
        { "name": "LG", "slug": "lg", "size": "32px" },
        { "name": "XL", "slug": "xl", "size": "48px" },
        { "name": "2XL", "slug": "2xl", "size": "80px" }
      ]
    },

    "border": {
      "radius": [
        { "name": "SM", "slug": "sm", "size": "6px" },
        { "name": "MD", "slug": "md", "size": "12px" },
        { "name": "LG", "slug": "lg", "size": "20px" },
        { "name": "XL", "slug": "xl", "size": "28px" }
      ]
    },

    "shadow": {
      "presets": [
        {
          "name": "Soft",
          "slug": "soft",
          "shadow": "0 6px 20px rgba(0,0,0,0.08)"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "shadow": "0 10px 30px rgba(0,0,0,0.12)"
        }
      ]
    },

    "custom": {
      "container": "1200px",
      "sectionSpacing": "80px"
    }
  },

  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--iransans)",
      "lineHeight": "1.7"
    },

    "elements": {
      "h1": { "typography": { "fontSize": "40px", "lineHeight": "1.2" } },
      "h2": { "typography": { "fontSize": "32px", "lineHeight": "1.3" } },
      "h3": { "typography": { "fontSize": "24px", "lineHeight": "1.4" } },
      "p": { "typography": { "fontSize": "16px" } },

      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "#ffffff"
        },
        "border": {
          "radius": "12px"
        }
      },

      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      }
    },

    "spacing": {
      "blockGap": "20px"
    }
  }
}
